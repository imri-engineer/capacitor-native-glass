{
  "name": "capacitor-native-glass",
  "version": "0.1.1",
  "description": "Native iOS 26 Liquid Glass surfaces (nav bar, toolbar, FAB, panel, controls, morphing, mini-player) rendered as overlays for Capacitor apps.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/",
    "ios/",
    "Package.swift",
    "CapacitorNativeGlass.podspec"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.js --external:@capacitor/core",
    "build:cjs": "esbuild src/index.ts --bundle --format=cjs --outfile=dist/index.cjs --external:@capacitor/core",
    "build:types": "tsc --project tsconfig.build.json --emitDeclarationOnly",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "verify:ios": "cd ios && swift build",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "capacitor",
    "capacitor-plugin",
    "ios",
    "ios26",
    "liquid-glass",
    "native-ui",
    "glass-effect"
  ],
  "capacitor": {
    "ios": {
      "src": "ios"
    }
  },
  "peerDependencies": {
    "@capacitor/core": ">=8.0.0"
  },
  "devDependencies": {
    "@capacitor/core": "^8.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/imri-engineer/capacitor-native-glass.git"
  },
  "author": "imri-engineer",
  "license": "MIT"
}
